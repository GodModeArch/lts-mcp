{
  "name": "lts-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "migrations": [{ "new_sqlite_classes": ["LtsMCP"], "tag": "v1" }],
  "durable_objects": {
    "bindings": [{ "class_name": "LtsMCP", "name": "MCP_OBJECT" }]
  },
  "vars": {
    "LAST_SYNCED": "2026-03-04"
  },
  "observability": { "enabled": true },
  "routes": [
    { "pattern": "lts.godmode.ph/*", "zone_name": "godmode.ph" }
  ]
}
